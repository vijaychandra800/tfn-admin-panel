rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
  
  	match /categories/{document=**} {
    	allow read : if true;
      allow write: if isUserSignedIn() && isAdmin();
    }
    
    match /tags/{document=**} {
    	allow read : if true;
      allow write: if isUserSignedIn() && (isAdmin() || isAuthor());
    }
    
    match /articles/{document=**} {
    	allow read : if true;
      allow update: if 
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['views'])) || 
        (isUserSignedIn() && (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes']))) ||
      	 isAdmin() || isAuthor();
      allow create, delete: if isUserSignedIn() && (isAdmin() || isAuthor());
    }
    
    match /events/{eventId} {
    	allow read : if true;
      allow update: if 
        isUserSignedIn() ||
      	 isAdmin() || isAuthor();
      allow create, delete: if isUserSignedIn() && (isAdmin() || isAuthor());
    }

    // Polls live as a subcollection under events.
    // Anyone may read; only admins/authors may create/update/delete poll docs.
    // Vote count updates triggered by user votes are handled in a transaction
    // alongside writing the user's own vote doc — we allow signed-in users to
    // update only the `options` field so that the transactional increment works.
    match /events/{eventId}/polls/{pollId} {
      allow read: if true;
      allow create, delete: if isUserSignedIn() && (isAdmin() || isAuthor());
      allow update: if (isUserSignedIn() && (isAdmin() || isAuthor()))
        || (isUserSignedIn()
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['options', 'updated_at']));

      // One vote document per user, keyed by uid.
      match /votes/{userId} {
        allow read: if true;
        allow create, update: if isUserSignedIn() && request.auth.uid == userId;
        allow delete: if isUserSignedIn() && (request.auth.uid == userId || isAdmin());
      }
    }
    
    match /notifications/{document=**} {
    	allow read : if true;
      allow write: if isUserSignedIn() && isAdmin();
    }
    
    match /comments/{document=**} {
    	allow read : if true;
      allow create : if isUserSignedIn() && !isMuted()
        && (isAdmin() || eventChatWritable(request.resource.data));
      allow update : if isUserSignedIn()
        && (isAdmin() || eventChatWritable(resource.data));
      allow delete: if isUserSignedIn();
    }
    
    match /purchases/{document=**} {
    	allow read : if true;
      allow create: if isUserSignedIn();
    }
    
    match /settings/{document=**} {
    	allow read : if true;
      allow write: if isUserSignedIn() && isAdmin();
    }
    
    match /user_stats/{document=**} {
    	allow read : if true;
      allow write: if isUserSignedIn();
    }
    
    match /purchase_stats/{document=**} {
    	allow read : if true;
      allow write: if isUserSignedIn();
    }
    
    match /users/{document=**} {
    	allow read : if true;
      allow create: if isUserSignedIn() && request.auth.uid == request.resource.id;
      allow update: if isUserSignedIn() && (
      	request.auth.uid == request.resource.id || isAdmin()
      )
      
      allow delete: if isUserSignedIn() && request.auth.uid == resource.id;
    }

    // Per-user Fanzone read tracking. Each doc is keyed by eventId and lives
    // under users/{userId}/event_chat_reads/{eventId}. The recursive
    // users/{document=**} rule above can't grant writes here because its
    // create/update checks compare request.auth.uid to the leaf doc id (the
    // eventId), not the userId — so an explicit rule scoped to {userId} is
    // required for the unread-badge mark-as-read write to succeed.
    match /users/{userId}/event_chat_reads/{eventId} {
      allow read, write: if isUserSignedIn() && request.auth.uid == userId;
    }
		
  
  	function isUserSignedIn (){
    	return request.auth != null;
    }
    
    function isAdmin (){
    	return "admin" in get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }
    
    function isAuthor (){
    	return "author" in get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    // Returns true when the authenticated user has an active mute window.
    // `muted_until` is removed entirely on unmute, so a missing field means
    // "not muted".
    function isMuted (){
      let userDoc = get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
      return 'muted_until' in userDoc && userDoc.muted_until > request.time;
    }

    // Admin-configured Fanzone read-only window (hours after an event ends).
    // Falls back to 72h when the setting is absent.
    function chatReadOnlyHours (){
      let s = get(/databases/$(database)/documents/settings/app).data;
      return 'chat_read_only_hours' in s ? s.chat_read_only_hours : 72;
    }

    // Event chats stay writable only until `end_date_time + chatReadOnlyHours`.
    // Article comments (and comments missing a target_type) are always
    // writable here. Deletion is handled separately by the purge job.
    function eventChatWritable (commentData){
      return !('target_type' in commentData)
        || commentData.target_type != 'event'
        || (
          request.time <
          get(/databases/$(database)/documents/events/$(commentData.target_id)).data.end_date_time
            + duration.value(chatReadOnlyHours(), 'h')
        );
    }
  }
}
